{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ndara.ai Business Owner AI - Data Schemas",
  "description": "Data schemas for Business Owner AI backend integration. Note: Invoice generation schemas are now in the invoice_generator service. Inventory management schemas are now in the inventory_management service.",
  "version": "1.2.0",
  
  "schemas": {
    "sales_data": {
      "type": "object",
      "description": "Sales transaction data",
      "properties": {
        "transaction_id": {"type": "string"},
        "business_id": {"type": "string"},
        "customer_id": {"type": "string"},
        "date": {"type": "string", "format": "date-time"},
        "amount": {"type": "number"},
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "quantity": {"type": "integer"},
              "price": {"type": "number"},
              "category": {"type": "string"}
            }
          }
        },
        "payment_method": {"type": "string"},
        "status": {"type": "string", "enum": ["completed", "pending", "refunded"]}
      }
    },
    
    "customer_profile": {
      "type": "object",
      "description": "Customer profile for segmentation",
      "properties": {
        "customer_id": {"type": "string"},
        "total_spent": {"type": "number"},
        "purchase_count": {"type": "integer"},
        "conversation_count": {"type": "integer"},
        "days_since_last_purchase": {"type": "integer"},
        "days_since_last_activity": {"type": "integer"},
        "purchased_products": {"type": "array", "items": {"type": "string"}},
        "interested_categories": {"type": "array", "items": {"type": "string"}},
        "preferred_contact_method": {"type": "string"}
      }
    },
    
    "inventory_retrieval_query": {
      "type": "object",
      "description": "Inventory retrieval/search query data",
      "properties": {
        "query": {
          "type": "string",
          "description": "Natural language query for inventory search (e.g., 'show low stock items', 'find product ABC-123', 'what services are available?')"
        },
        "context": {
          "type": "object",
          "description": "Additional context for inventory search",
          "properties": {
            "filters": {
              "type": "object",
              "properties": {
                "stock_level": {"type": "string", "enum": ["low", "zero", "high"]},
                "category": {"type": "string"},
                "product_name": {"type": "string"},
                "price_min": {"type": "number"},
                "price_max": {"type": "number"},
                "date_range": {"type": "string"},
                "staff_name": {"type": "string"},
                "resource_type": {"type": "string"}
              }
            },
            "predict_demand": {"type": "boolean"},
            "conversations": {"type": "array", "items": {"type": "object"}}
          }
        }
      },
      "required": ["query"]
    },
    
    "business_analytics": {
      "type": "object",
      "description": "Business performance analytics",
      "properties": {
        "business_id": {"type": "string"},
        "period": {"type": "string"},
        "total_revenue": {"type": "number"},
        "total_transactions": {"type": "integer"},
        "avg_order_value": {"type": "number"},
        "customer_count": {"type": "integer"},
        "new_customers": {"type": "integer"},
        "returning_customers": {"type": "integer"},
        "top_products": {"type": "array"},
        "conversion_rate": {"type": "number"},
        "customer_satisfaction": {"type": "number"}
      }
    },
    
    "segment_definition": {
      "type": "object",
      "description": "Customer segment definition",
      "properties": {
        "segment_id": {"type": "string"},
        "segment_name": {"type": "string"},
        "customer_ids": {"type": "array", "items": {"type": "string"}},
        "size": {"type": "integer"},
        "characteristics": {"type": "string"},
        "avg_value": {"type": "number"},
        "recommended_strategy": {"type": "string"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    
    "broadcast_campaign": {
      "type": "object",
      "description": "Broadcast message campaign",
      "properties": {
        "campaign_id": {"type": "string"},
        "business_id": {"type": "string"},
        "message_intent": {"type": "string"},
        "target_segment": {"type": "string"},
        "message_content": {"type": "string"},
        "scheduled_time": {"type": "string", "format": "date-time"},
        "status": {"type": "string", "enum": ["draft", "scheduled", "sent", "cancelled"]},
        "metrics": {
          "type": "object",
          "properties": {
            "sent_count": {"type": "integer"},
            "delivered_count": {"type": "integer"},
            "opened_count": {"type": "integer"},
            "clicked_count": {"type": "integer"}
          }
        }
      }
    },
    
    "invoice_retrieval_query": {
      "type": "object",
      "description": "Invoice retrieval/search query data",
      "properties": {
        "query": {
          "type": "string",
          "description": "Natural language query for invoice search (e.g., 'show unpaid invoices', 'find invoice INV-123', 'invoices from last month')"
        },
        "context": {
          "type": "object",
          "description": "Additional context for invoice search",
          "properties": {
            "filters": {
              "type": "object",
              "properties": {
                "invoice_number": {"type": "string"},
                "customer_email": {"type": "string"},
                "status": {"type": "string", "enum": ["pending", "paid", "overdue", "refunded"]},
                "date_from": {"type": "string", "format": "date"},
                "date_to": {"type": "string", "format": "date"},
                "min_amount": {"type": "number"},
                "max_amount": {"type": "number"}
              }
            }
          }
        }
      },
      "required": ["query"]
    },
    
    "competitive_insights_data": {
      "type": "object",
      "description": "Competitive intelligence analysis data",
      "required": ["business_data"],
      "properties": {
        "business_data": {
          "type": "object",
          "description": "Business information and profile for competitive analysis",
          "required": ["business_profile"],
          "properties": {
            "business_profile": {
              "type": "object",
              "properties": {
                "business_name": {"type": "string"},
                "industry": {"type": "string"},
                "description": {"type": "string"},
                "contact_info": {
                  "type": "object",
                  "properties": {
                    "email": {"type": "string", "format": "email"},
                    "phone": {"type": "string"},
                    "address": {"type": "string"},
                    "website": {"type": "string", "format": "uri"}
                  }
                },
                "products_services": {"type": "array"},
                "pricing_strategy": {"type": "string"},
                "target_market": {"type": "string"},
                "unique_selling_points": {"type": "array", "items": {"type": "string"}},
                "customer_base_size": {"type": "integer"},
                "revenue_range": {"type": "string"}
              }
            },
            "performance_metrics": {
              "type": "object",
              "properties": {
                "revenue": {"type": "number"},
                "customer_count": {"type": "integer"},
                "market_share": {"type": "number"},
                "growth_rate": {"type": "number"}
              }
            }
          }
        },
        "similar_businesses": {
          "type": "array",
          "description": "Information about similar/competitor businesses",
          "items": {
            "type": "object",
            "properties": {
              "business_name": {"type": "string"},
              "industry": {"type": "string"},
              "description": {"type": "string"},
              "products_services": {"type": "array"},
              "pricing_strategy": {"type": "string"},
              "target_market": {"type": "string"},
              "unique_selling_points": {"type": "array", "items": {"type": "string"}},
              "customer_base_size": {"type": "integer"},
              "revenue_range": {"type": "string"},
              "performance_metrics": {
                "type": "object",
                "properties": {
                  "revenue": {"type": "number"},
                  "customer_count": {"type": "integer"},
                  "market_share": {"type": "number"},
                  "growth_rate": {"type": "number"}
                }
              }
            }
          }
        }
      }
    }
  },
  
  "notes": {
    "database_recommendations": {
      "analytics_db": "Time-series database recommended for analytics (InfluxDB, TimescaleDB)",
      "customer_data": "PostgreSQL with JSONB for flexible customer profiles",
      "real_time": "Redis for real-time analytics and caching"
    },
    "api_integration": {
      "mobile_app": "Business owner requests analytics via API endpoints",
      "web_dashboard": "Real-time dashboard powered by AI analytics",
      "notifications": "Backend handles push notifications based on AI insights"
    }
  }
}

